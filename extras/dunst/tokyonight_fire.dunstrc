# TokyoNight colors for dunst
# For more configuration options see https://github.com/dunst-project/dunst/blob/master/dunstrc

[urgency_low]
    background = "#150e0c"
    foreground = "#fff4ee"
    frame_color = "#fff4ee"

[urgency_normal]
    background = "#1b1310"
    foreground = "#fff4ee"
    frame_color = "#fff4ee"

[urgency_critical]
    background = "#30201b"
    foreground = "#de5152"
    frame_color = "#de5152"
