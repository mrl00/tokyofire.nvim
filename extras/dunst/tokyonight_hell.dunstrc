# TokyoNight colors for dunst
# For more configuration options see https://github.com/dunst-project/dunst/blob/master/dunstrc

[urgency_low]
    background = "#150b07"
    foreground = "#fff0e5"
    frame_color = "#fff0e5"

[urgency_normal]
    background = "#1c0f0a"
    foreground = "#fff0e5"
    frame_color = "#fff0e5"

[urgency_critical]
    background = "#331a12"
    foreground = "#dd3333"
    frame_color = "#dd3333"
